{
  "manifest_version": 3,
  "name": "🎬 我的视频助手",
  "version": "2.0",
  "description": "可设置跳过片头秒数，并自动下一集",
  "permissions": ["storage"],   // 移除 "windows" 权限
  "action": {
    "default_popup": "popup.html",    // 改回这行
    "default_title": "视频助手设置"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}